{
  "name": "@elastic/mcp-server-elasticsearch",
  "description": "Elasticsearch MCP Server",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "author": "Simon Owusu",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-server-elasticsearch": "./dist/index.js"
  },
  "keywords": [
    "elasticsearch",
    "search",
    "mcp",
    "mcp-server"
  ],
  "files": [
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun run dist/index.js",
    "inspector": "bun x --bun @modelcontextprotocol/inspector bun ./dist/index.js",
    "build:inspector": "bun run build && bun run inspector",
    "inspector:sse": "bun run scripts/run-inspector.js",
    "proxy:sse": "bun run scripts/sse-inspector-proxy.js",
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "validate-config": "bun run scripts/validate-config.ts",
    "validate-config:full": "bun run scripts/validate-config.ts --check-connection --show-all",
    "test-connection": "bun run scripts/test-connection.ts"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.0.2",
    "@elastic/transport": "^9.0.2",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/bun": "^1.2.15",
    "content-type": "^1.0.5",
    "http-proxy": "^1.18.1",
    "raw-body": "^2.5.2",
    "zod": "^3.25.51"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "bun-types": "^1.2.15",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
