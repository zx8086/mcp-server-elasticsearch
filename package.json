{
  "name": "@elastic/mcp-server-elasticsearch",
  "description": "Elasticsearch MCP Server with 170+ tools for comprehensive Elasticsearch operations",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "author": "Simon Owusu",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcp-server-elasticsearch": "./dist/index.js"
  },
  "keywords": [
    "elasticsearch",
    "search",
    "mcp",
    "mcp-server"
  ],
  "files": [
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap=external --splitting --public-path=/assets/",
    "build:dev": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap=inline",
    "build:production": "bun build ./src/index.ts --outdir ./dist --target bun --minify --sourcemap=external --splitting --define:\"process.env.NODE_ENV=\\\"production\\\"\" --define:\"typeof Bun=\\\"object\\\"\"",
    "build:analyze": "bun build ./src/index.ts --outdir ./dist --target bun --analyze",
    "start": "bun run dist/index.js",
    "start:production": "NODE_ENV=production bun run dist/index.js",
    "inspector": "bun x --bun @modelcontextprotocol/inspector bun ./dist/index.js",
    "build:inspector": "bun run build && bun run inspector",
    "connectivity-test": "bun run scripts/connectivity-test.js",
    "dev": "bun run src/index.ts",
    "dev:hot": "bun --hot run src/index.ts",
    "test": "bun test tests/unit tests/validation",
    "test:all": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "test:validation": "bun test tests/validation",
    "test:infrastructure": "bun test tests/infrastructure",
    "test:config": "bun test tests/unit/config",
    "test:tools": "bun test tests/integration/tools",
    "test:e2e": "bun test tests/integration/e2e",
    "test:monitoring": "bun test tests/infrastructure/monitoring",
    "test:performance": "bun test tests/infrastructure/performance",
    "test:security": "bun test tests/infrastructure/security",
    "test:ci": "bun test tests/unit tests/validation",
    "test:pre-deploy": "bun test tests/unit tests/validation tests/integration",
    "test:dev": "bun run tests/dev/manual/run-dev-tests.ts",
    "test:working": "bun test tests/unit tests/validation tests/infrastructure",
    "typecheck": "bunx tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "biome:check": "biome check .",
    "biome:check:write": "biome check --write .",
    "yaml:check": "find . -name '*.yml' -o -name '*.yaml' | grep -v node_modules | xargs yamllint -d '{extends: relaxed, rules: {line-length: disable}}'",
    "validate-config": "bun run scripts/validate-config.ts",
    "validate-config:full": "bun run scripts/validate-config.ts --check-connection --show-all",
    "test-connection": "bun run scripts/test-connection.ts",
    "validate-schemas": "bun run scripts/validate-schemas.ts",
    "pre-commit": "bun run lint && bun run validate-schemas",
    "benchmark": "bun run scripts/benchmark.ts",
    "memory-profile": "bun --heap-prof run src/index.ts",
    "generate-docs": "bun run scripts/generate-docs.ts",
    "docs": "bun run generate-docs && echo 'Open docs/api/index.html in your browser'",
    "docs:serve": "bun run generate-docs && python3 -m http.server 8000 --directory docs/api",
    "dev-tools": "bun run scripts/dev-tools.ts",
    "dev-tools:full": "bun run scripts/dev-tools.ts --with-tests --with-profiling",
    "dev-tools:minimal": "bun run scripts/dev-tools.ts --no-lint --no-type-check --no-monitoring",
    "health-check": "echo 'Use elasticsearch_diagnostics tool or elasticsearch_get_cluster_health tool instead'"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@elastic/transport": "^9.3.5",
    "@langchain/core": "^1.1.31",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/bun": "^1.3.10",
    "langsmith": "^0.5.8",
    "raw-body": "^3.0.2",
    "zod": "4.3.6"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@elastic/elasticsearch-mock": "^2.1.0",
    "@types/node": "^25.3.5",
    "bun-types": "^1.3.10",
    "c8": "^11.0.0",
    "typescript": "^5.9.3"
  },
  "bun": {
    "install": {
      "peer": true,
      "frozenLockfile": true,
      "cache": {
        "dir": ".bun-cache"
      }
    },
    "build": {
      "target": "bun",
      "minify": true,
      "sourcemap": "external",
      "splitting": true,
      "define": {
        "process.env.NODE_ENV": "production",
        "typeof Bun": "object"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "private": true
}
