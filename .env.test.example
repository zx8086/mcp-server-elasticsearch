# Test Environment Configuration
# Copy this file to .env.test and configure for your test Elasticsearch cluster

# Elasticsearch Connection (uses same variables as main .env)
ELASTICSEARCH_URL=http://localhost:9200
# ELASTICSEARCH_API_KEY=your-api-key-here
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme
# ELASTICSEARCH_CA_CERT=

# Test-specific Configuration
SKIP_INTEGRATION_TESTS=false
TEST_INDEX_PREFIX=test-mcp
TEST_CLEANUP_INDICES=true

# Server Configuration (for tests)
SERVER_NAME=elasticsearch-mcp-test-server
MCP_READ_ONLY_MODE=false
MCP_READ_ONLY_STRICT_MODE=false

# Logging for tests
LOG_LEVEL=error

# Response handling (smaller for tests)
MAX_RESPONSE_SIZE_BYTES=100000
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=50