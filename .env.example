# Elasticsearch MCP Server Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Elasticsearch server URL (REQUIRED)
ES_URL=http://localhost:9200

# =============================================================================
# AUTHENTICATION (Choose one method)
# =============================================================================

# Method 1: API Key Authentication (Recommended)
# ES_API_KEY=your_api_key_here

# Method 2: Username/Password Authentication
# ES_USERNAME=your_username
# ES_PASSWORD=your_password

# Method 3: No Authentication (Local development only)
# Leave both API key and username/password empty

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Server identification
# MCP_SERVER_NAME=elasticsearch-mcp-server
# MCP_SERVER_VERSION=0.1.1

# Read-Only Mode Configuration
# Enables read-only mode to protect against destructive operations
READ_ONLY_MODE=true

# Controls strictness of read-only mode
# true = Block destructive operations completely (recommended for production)
# false = Allow destructive operations but show warnings (good for development)
READ_ONLY_STRICT_MODE=true

# Query and result limits
# MCP_MAX_QUERY_TIMEOUT=30000
# MCP_MAX_RESULTS_PER_QUERY=1000

# Transport settings
# MCP_TRANSPORT=stdio
# MCP_PORT=8080

# =============================================================================
# ELASTICSEARCH CLIENT CONFIGURATION
# =============================================================================

# TLS/SSL Configuration
# ES_CA_CERT=/path/to/ca-certificate.pem

# Connection settings
# ES_MAX_RETRIES=3
# ES_REQUEST_TIMEOUT=30000
# ES_COMPRESSION=true

# Client metadata and headers
# ES_ENABLE_META_HEADER=true
# ES_DISABLE_PROTOTYPE_POISONING_PROTECTION=true

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
# LOG_FORMAT=json

# Include metadata in logs
# LOG_INCLUDE_METADATA=true

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Permission settings (use with caution)
# ALLOW_DESTRUCTIVE_OPERATIONS=false
# ALLOW_SCHEMA_MODIFICATIONS=false
# ALLOW_INDEX_MANAGEMENT=false

# Bulk operation limits
# MAX_BULK_OPERATIONS=1000

# =============================================================================
# OPTIONAL MONITORING (AUTO-DETECTED)
# =============================================================================

# Monitoring System Configuration
# ===============================
# The server includes comprehensive Prometheus metrics collection that is:
# - AUTOMATICALLY DETECTED: No configuration required
# - GRACEFULLY DEGRADED: Works without monitoring dependencies
# - ZERO CONFIGURATION: No environment variables needed
#
# To enable monitoring:
# 1. Install optional dependency: bun add prom-client
# 2. Server automatically detects and starts metrics endpoint
# 3. Metrics available at: http://localhost:9090/metrics
# 4. Health check at: http://localhost:9090/health
#
# Features when enabled:
# - 50+ comprehensive metrics (tool execution, performance, errors, system health)
# - Circuit breaker state monitoring
# - Connection pool health and performance metrics  
# - Cache hit ratios and operation statistics
# - Elasticsearch response times and error tracking
# - Security validation and read-only mode metrics
# - System resource monitoring (CPU, memory)
#
# Default Settings (no configuration needed):
# - METRICS_PORT: 9090 (hardcoded)
# - METRICS_PATH: /metrics (standard)
# - HEALTH_PATH: /health (standard)
# - AUTO_START: true (if prom-client available)
#
# Commands to check monitoring status:
# bun run monitor:health   # Check if monitoring endpoint is running
# bun run monitor:metrics  # View available metrics
# bun run monitor:status   # Show monitoring configuration

# =============================================================================
# COMMON CONFIGURATION EXAMPLES
# =============================================================================

# Local Development Example:
# ES_URL=http://localhost:9200
# LOG_LEVEL=debug
# READ_ONLY_MODE=false

# Elastic Cloud Example:
# ES_URL=https://your-deployment.es.us-central1.gcp.cloud.es.io:443
# ES_API_KEY=your_cloud_api_key
# READ_ONLY_MODE=true
# LOG_LEVEL=info

# Production Example:
# ES_URL=https://elasticsearch.yourcompany.com:9200
# ES_API_KEY=your_production_api_key
# ES_CA_CERT=/etc/ssl/certs/elasticsearch-ca.pem
# READ_ONLY_MODE=true
# READ_ONLY_STRICT_MODE=true
# LOG_LEVEL=warn
# ES_MAX_RETRIES=5
# ES_REQUEST_TIMEOUT=60000

# Self-Hosted with Authentication Example:
# ES_URL=https://elasticsearch.internal:9200
# ES_USERNAME=mcp_service
# ES_PASSWORD=secure_service_password
# ES_CA_CERT=/opt/certs/elasticsearch-ca.pem
# READ_ONLY_MODE=false
# LOG_LEVEL=info
